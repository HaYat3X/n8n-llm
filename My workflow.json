      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.response ?? \"\";\nconst clean = raw\n  .replace(/\\\\n/g, '\\n')\n  .replace(/\\*\\*/g, '')      // **太字** を除去\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .trim();\n\nreturn [{ json: { text: clean } }];"
      },
