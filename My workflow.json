    {
      "parameters": {
        "jsCode": "const keywords = $input.first().json.response.trim().split(\",\").map(k => k.trim()).filter(Boolean);\n\nconst orFilter = keywords.map(keyword => ({\n  or: [\n    { property: \"名前\", title: { contains: keyword } },\n    { property: \"概要\", rich_text: { contains: keyword } },\n    { property: \"タグ\", multi_select: { contains: keyword } }\n  ]\n}));\n\nreturn [{ json: { filter: { or: orFilter } } }];"
      },
