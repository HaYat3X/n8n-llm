    {
      "parameters": {
        "jsCode": "const allPages = $input.all();\nconst question = $('When chat message received').first().json.chatInput;\n\nconst context = allPages\n  .map(p => p.json.pageText)\n  .filter(Boolean)\n  .join(\"\\n\\n---\\n\\n\");\n\nconst prompt = `以下のコンテキストを根拠に質問に答えてください。コンテキストに答えがない場合は「情報がありません」と答えてください。\\n\\nコンテキスト:\\n${context}\\n\\n質問: ${question}\\n回答:`;\n\nreturn [{ json: { prompt } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        -80
      ],
